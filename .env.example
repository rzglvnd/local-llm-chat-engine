# Local LLM Chat Engine
LOCAL_LLM_HOST=0.0.0.0
LOCAL_LLM_PORT=8001
LOCAL_LLM_LOG_LEVEL=INFO
LOCAL_LLM_DEFAULT_K=3
LOCAL_LLM_MAX_K=20
LOCAL_LLM_API_KEY=
LOCAL_LLM_CORS_ORIGINS=
LOCAL_LLM_SNAPSHOT_PATH=./data/store.pkl
LOCAL_LLM_AUTOLOAD_SNAPSHOT=true
LOCAL_LLM_FAIL_ON_SNAPSHOT_ERROR=false
LOCAL_LLM_STREAM_CHUNK_SIZE=64
LOCAL_LLM_RATE_LIMIT_ENABLED=false
LOCAL_LLM_RATE_LIMIT_REQUESTS_PER_MINUTE=120
LOCAL_LLM_RATE_LIMIT_WINDOW_SECONDS=60
LOCAL_LLM_RATE_LIMIT_EXEMPT_PATHS=/health,/ready
OPENAI_API_KEY=
